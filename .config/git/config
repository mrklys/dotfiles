[user]
	email = mr.klys@ukr.net
	name = Andriy Klys
[init]
	defaultBranch = master
[core]
	editor = nvim
	autocrlf = input
	excludesfile = ~/.config/git/ignore
[diff]
	algorithm = histogram
	colorMoved = plain
	mnemonicPrefix = true
	renames = true
[commit]
	verbose = true
[fetch]
	prune = true
	pruneTags = true
	all = true
[pull]
    ff = only
[merge]
	ff = false
	stat = true
[rebase]
	autoSquash = true
	autoStash = true
	updateRefs = true
[rerere]
	enabled = true
	autoupdate = true
[branch]
	sort = -committerdate
[tag]
	sort = version:refname
[color]
	ui = auto
[column]
	ui = auto
[help]
	autocorrect = prompt

[alias]
	# Basic Commands
	stat = "!f() { git status && git diff --shortstat; }; f"
	comm = commit -v -m
	gitk = !gitk --all --branches
	su   = submodule update --recursive
	# Workflow & WIP
	amend = commit --amend --no-edit -v
	fix   = commit -v --fixup
	wip   = "!f() { git add -A && git commit -m \"___WIP___\"; }; f"
	rewip = reset --soft HEAD^
	# Stashing
	hide   = stash push -m "temp_backup" --include-untracked
	rehide = stash pop stash@{0}
	# Reset & Cleanup
	unstage = reset HEAD --
	cleanup = reset --hard
	# Utilities
	initempty = "!f() { git init && git commit -m \"root\" --allow-empty; }; f"
	please    = push -v --force-with-lease
	track     = update-index --no-assume-unchanged --verbose
	untrack   = update-index --assume-unchanged --verbose
	# Logging
	logs = log --graph --pretty=format:'%Cred%h%Creset -%C(yellow)%d%Creset %s %Cgreen(%cr)%C(bold blue)<%an>%Creset' --abbrev-commit
	tree = log --graph --abbrev-commit --decorate --all --format=format:\"%C(bold blue)%h%C(reset) - %C(bold cyan)%aD%C(dim white) - %an%C(reset) %C(bold green)(%ar)%C(reset)%C(bold yellow)%d%C(reset)%n %C(white)%s%C(reset)\"

